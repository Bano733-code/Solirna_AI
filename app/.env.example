# --- Security ---
SECRET_KEY=your_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PostgreSQL (ONLY relational data now) ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# --- Fireworks AI ---
FIREWORKS_API_KEY=fw_xxxxx
LLM_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
EMBEDDING_MODEL=accounts/fireworks/models/nomic-embed-text-v1_5

# --- Qdrant (NEW - VECTOR DATABASE) ---
QDRANT_URL=https://your-qdrant-cluster-url
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=solirna_memory
